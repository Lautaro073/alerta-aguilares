# ---------------------------------------------------------------------------
#  FIREBASE ADMIN SDK  (solo servidor — NUNCA exponer al cliente)
#
#  Conseguís estas credenciales en:
#  Firebase Console → Configuración del Proyecto → Cuentas de Servicio
#  → "Generar nueva clave privada" (descarga un archivo JSON)
#
#  En DESARROLLO LOCAL con emuladores no son necesarias (dejalas vacías).
#  En PRODUCCIÓN son OBLIGATORIAS.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=

# Del JSON de cuenta de servicio → campo "client_email"
FIREBASE_CLIENT_EMAIL=

# Del JSON de cuenta de servicio → campo "private_key"
# IMPORTANTE: En el archivo .env.local, pegá el contenido tal cual
# (con los -----BEGIN PRIVATE KEY----- incluidos).
# En Vercel u otros hosts, reemplazá los saltos de línea reales por \n
FIREBASE_PRIVATE_KEY=


# ---------------------------------------------------------------------------
#  RATE LIMITING (Anti-spam de reportes)
#
#  HASH_SALT: Cadena aleatoria larga (mín. 32 caracteres) usada para
#  anonimizar las huellas digitales (IPs y fingerprints) antes de guardarlas.
#  Generá una con: openssl rand -base64 48
#  En PRODUCCIÓN es OBLIGATORIA una clave real y secreta.
# ---------------------------------------------------------------------------
HASH_SALT=cambia_esto_por_una_cadena_aleatoria_segura_de_minimo_32_chars

# Máximo de reportes permitidos por día (por huella de navegador)
MAX_REPORTS_PER_DAY_FP=5

# Máximo de reportes permitidos por día (por IP de red)
MAX_REPORTS_PER_DAY_IP=10

# Ventana de tiempo del rate limit en horas
RATE_LIMIT_WINDOW_HOURS=24

# ---------------------------------------------------------------------------
#  CORS / PROTECCIÓN DE API
#
#  URL de tu frontend. En producción debe ser la URL real de Vercel.
#  Ejemplo producción: https://ciudadalerta.vercel.app
# ---------------------------------------------------------------------------
ALLOWED_ORIGIN=*


# ---------------------------------------------------------------------------
#  GOOGLE MAPS  (Opcional — solo para la funcionalidad de Street View)
#
#  Conseguís la clave en: https://console.cloud.google.com/
#  → APIs y Servicios → Credenciales → Crear Clave de API
#  → Habilitá la API "Maps JavaScript API" y "Street View Static API"
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
#  FIREBASE CLIENT CONFIG (explicito para cliente y emuladores)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY

# Cloudinary (almacenamiento de fotos de reportes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
